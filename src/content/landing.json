  "hero_eyebrow":    { "ru": "PsyID · ReNo", "en": "PsyID · ReNo" },
  "hero_h1a":        { "ru": "Ты — целая",   "en": "You are a whole" },
  "hero_h1b":        { "ru": "вселенная.",   "en": "universe." },
  "hero_p":          { "ru": "Пять осей характера в ядре. Планеты, спутники и созвездия — вокруг. Всё построено из твоих ответов, и всё — измерено.", "en": "Five axes of character at the core. Planets, moons and constellations around them. All of it built from your answers, and all of it measured." },
  "hero_cta":        { "ru": "Исследовать свою галактику", "en": "Explore your galaxy" },
  "hero_cta2":       { "ru": "Пройти тест",  "en": "Take the test" },
  "hero_micro":      { "ru": "94 вопроса · 15 минут · научная методика", "en": "94 questions · 15 minutes · a real method" },
  "hero_grabhint":   { "ru": "потяни, чтобы вращать", "en": "drag to spin" },

  "code_eyebrow":    { "ru": "Твой код", "en": "Your code" },
  "code_h":          { "ru": "У твоей личности есть координаты.", "en": "Your personality has coordinates." },
  "code_p":          { "ru": "Каждая ось — непрерывная шкала от 0 до 100, а не ярлык. Твой код — это позиция сразу на пяти шкалах. Двух одинаковых практически не бывает.", "en": "Each axis is a continuous 0–100 scale, not a label. Your code is your position on all five at once. Two the same almost never happen." },

  "grow_eyebrow":    { "ru": "Как она растёт", "en": "How it grows" },
  "grow_ha":         { "ru": "Вселенная, которая", "en": "A universe that" },
  "grow_hb":         { "ru": "не заканчивается",   "en": "never finishes" },
  "grow1_t":         { "ru": "Звёзды и планеты", "en": "Stars and planets" },
  "grow1_d":         { "ru": "Ядро — пять осей характера. Вокруг каждой вращаются планеты: из чего именно у тебя состоит эта черта.", "en": "The core is five axes of character. Planets orbit each one — what that trait is actually made of in you." },
  "grow2_t":         { "ru": "Линзы", "en": "Lenses" },
  "grow2_d":         { "ru": "Включи линзу — и увидишь, как твоя вселенная сдвигается: дома, на работе, под нагрузкой. Та же личность — в разных сферах жизни.", "en": "Turn a lens and watch your universe shift — at home, at work, under load. The same personality across different parts of life." },
  "grow3_t":         { "ru": "Свет во времени", "en": "Light over time" },
  "grow3_d":         { "ru": "Раз в год — новый слой света. Видно, что изменилось, а что осталось ядром. Люди меняются — теперь это заметно.", "en": "Once a year, a new layer of light. You see what changed and what stayed the core. People change — now it shows." },

  "rigor_1":         { "ru": "Нормативная методика Ликерта", "en": "A normed Likert method" },
